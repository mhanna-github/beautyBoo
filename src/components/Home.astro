---
import { Image } from 'astro:assets';
import Shampoo from '../images/home1.jpg';
import Scrub from '../images/home2.jpg';
import Cream from '../images/home3.jpg';
import Face from '../images/home4.jpg';

---

<main>
    <section id="home" class="lg:relative lg:h-[80vh] mt-[6rem]">
        <div class="flex flex-col justify-center max-w-[40rem] lg:max-w-[29rem] xl:max-w-[40rem] lg:max-h-[27rem] xl:max-h-[40rem] mx-[1.5rem] lg:mx-[2rem] xl:mx-[5rem] lg:absolute lg:inset-0 z-20 items-start">
            <div class="flex flex-col items-center text-center gap-[0.3rem] lg:gap-[0.5rem] xl:gap-[0.9rem] lg:items-end lg:text-end">
                <h2 class="flex flex-col">
                    <span class="text-[3.6rem] lg:text-[4.5rem] xl:text-[5.5rem] font-bold font-monument text-blue">BlueCloud</span>
                    <span class="text-[2rem] lg:text-[2.5rem] xl:text-[2.8rem] uppercase -mt-[1.9rem] lg:-mt-[2.2rem] xl:-mt-[2.9rem] relative lg:text-[3.5rem]">Collection</span>
                </h2>
                <p class="text-[1rem] xl:text-[1.2rem] lg:max-w-[33rem] lg:text-start lg:pl-[5rem]">Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo.</p>
                <a href="" class="flex flex-row items-center gap-[0.2rem] text-blue uppercase my-[0.5rem]">
                    <span class="hover:underline hover:decoration-2 text-[1.5rem] lg:text-[1.8rem] xl:text-[2.3rem] h-[2rem] lg:h-[2.5rem] xl:h-[3rem]">Shop Now</span>
                    <svg class="lg:w-[2rem] lg:h-[2.5rem] xl:w-[2.5rem] xl:h-[3rem]" width="1.5rem" height="1.5rem" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 12L5 12" stroke="#8ABEE2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M12 19L19 12L12 5" stroke="#8ABEE2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>    
                </a>
            </div>
        </div>   

        <div class="swiper flex flex-col items-center z-1 text-center">
            <ul class="swiper-wrapper h-full lg:h-[80vh]">
                <li class="swiper-slide h-full" data-swiper-autoplay="5000">
                    <figure class="h-full">
                        <Image src={Shampoo} class="h-full object-cover w-full" alt="BlueCloud Collection" />
                    </figure>
                </li>
                <li class="swiper-slide h-full" data-swiper-autoplay="5000">
                    <figure class="h-full">
                        <Image src={Cream} class="h-full object-cover w-full" alt="BlueCloud Collection" />
                    </figure>
                </li>
                <li class="swiper-slide h-full" data-swiper-autoplay="5000">
                    <figure class="h-full">
                        <Image src={Scrub} class="h-full object-cover w-full" alt="BlueCloud Collection" />
                    </figure>
                </li>
                <li class="swiper-slide h-full" data-swiper-autoplay="5000">
                    <figure class="h-full">
                        <Image src={Face} class="h-full object-cover w-full" alt="BlueCloud Collection" />
                    </figure>
                </li>
            </ul>
            <div class="swiper-pagination flex flex-row gap-[0.5rem] lg:mb-[1rem] xl:mb-[1.3rem] mb-[0.6rem]"></div>
            <span class="text-[1.2rem] lg:text-[1.6rem] xl:text-[2rem] lg:font-thin">Enhance,  Empower,  Embrace Beauty</span>
        </div>
    </section>
</main>

<script>
    import Swiper from 'swiper';
    import { Pagination, Autoplay } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/pagination';

    document.addEventListener('DOMContentLoaded', function() {
        const swiper = new Swiper('.swiper', {
            direction: 'horizontal',
            loop: true,
            speed: 1000, 
            autoplay: {
                disableOnInteraction: false,
            },
            modules: [Pagination, Autoplay],
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            },
        });
    });
</script>

<style is:global>
    .swiper-pagination {
        position: relative !important;
        margin-top: 1rem;
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

    .swiper-pagination-bullet {
        height: 0.5rem !important;
        width: 6rem !important;
        background-color: #86b4cf !important;
        cursor: pointer;
        display: inline-block;
        border-radius: 0 !important;
        margin: 0 !important;
        position: relative !important;
        overflow: hidden !important;
    }

    .swiper-pagination-bullet-active::after {
        transform: translateX(0);
        transition: transform 5s linear;  
    }
    
    @media (min-width: 1024px) {
        .swiper-pagination-bullet {
            width: 10rem !important;
        }
    }
</style>